{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "vercel-python@0.1.0"
    }
  },
  "installCommand": "pip install -r backend/requirements.txt && cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build"
}
